#!/bin/bash

DIR_SOURCE='/home/che/'
DIR_DESTINATION='/mnt/smb/backups/che-home/'
DIR_RSYNC_BACKUP_LOGS='/var/log/rsync-backup'
LOG_SCRIPT='/var/log/cron-che-rsync.log'
LOG_RSYNC="$DIR_RSYNC_BACKUP_LOGS/$(date +%Y-%m-%d).log"

if [ ! -d $DIR_RSYNC_BACKUP_LOGS ]; then
    install --mode 750 --directory $DIR_RSYNC_BACKUP_LOGS
fi
if [ ! -f $LOG_SCRIPT ]; then
    install --mode 644 /dev/null $LOG_SCRIPT
fi
if [ ! -f $LOG_RSYNC ]; then
    install --mode 640 /dev/null $LOG_RSYNC
fi

stamp_time () {
    TZ="Europe/Belgrade" date "+%Y-%m-%d %H:%M:%S"
}
logcmd () {
    echo $(stamp_time) INFO "${@}" >> $LOG_SCRIPT
    echo $(stamp_time) INFO "${@}" >> $LOG_RSYNC
    logger --priority "local7.info" "${@}"
}

logcmd "Starting rsync backup..."

rsync \
    --times \
    --verbose \
    --compress \
    --hard-links \
    --partial \
    --progress \
    --mkpath \
    --recursive \
    --log-file=$LOG_RSYNC \
    --exclude '.cache/' \
    --exclude '.local/share' \
    --exclude '.cursor/' \
    --exclude '.dbus/' \
    --exclude '.docker/' \
    --exclude '.eclipse/' \
    --exclude '.rustup/' \
    --exclude 'Downloads/' \
    $DIR_SOURCE $DIR_DESTINATION

logcmd "End of rsync backup."
