#!/bin/bash

# vars
DESKTOP_USER=che
TEMPLATES_DIR="/home/$DESKTOP_USER/lib/templates"
ZYPPER_PARAMS_QUIET="--non-interactive --quiet"
ZYPPER_PARAMS_DUP="--no-allow-vendor-change --auto-agree-with-licenses --no-recommends"
FLATPAK_PARAMS_QUIET="--noninteractive --assumeyes"
WORKDIR="$(mktemp -d)"
SYSTEMD_NEEDS_RELOAD="no"
SNAPPER_ROOT_CONFIG="/etc/snapper/configs/root"
SNAPPER_ROOT_CONFIG_TPL="$TEMPLATES_DIR/snapper-root.conf"
SNAPPER_CLEANUP_TIMER_UNIT="/usr/lib/systemd/system/snapper-cleanup.timer"
SNAPPER_CLEANUP_TIMER_UNIT_TPL="$TEMPLATES_DIR/snapper-cleanup.timer"
JOURNALD_CONFIG="/etc/systemd/journald.conf.d/99-overrides.conf"
JOURNALD_CONFIG_TPL="$TEMPLATES_DIR/journald.conf"
LIBVIRT_DEFAULT_NETWORK_TPL="$TEMPLATES_DIR/libvirt-default-virbr0.xml"
LOG_SCRIPT="/var/log/dup.log"
# declate pairs of template and target system files for comparison
SYSTEM_FILES=("$SNAPPER_ROOT_CONFIG_TPL $SNAPPER_ROOT_CONFIG"
"$SNAPPER_CLEANUP_TIMER_UNIT_TPL $SNAPPER_CLEANUP_TIMER_UNIT")

if [ ! -f $LOG_SCRIPT ]; then
    sudo install --mode 644 /dev/null $LOG_SCRIPT
fi

# if common shell functions are loaded
if [ "$COMMON_BASH_LIB_LOADED" = "yes" ]; then
    logcmd () {
        log_message info "${@}"
        sudo dd status=none oflag=append conv=notrunc of=$LOG_SCRIPT <<< "$(stamp_time) INFO ${@}"
    }
else
    stamp_time () {
        TZ="Europe/Belgrade" date "+%Y-%m-%d %H:%M:%S"
    }
    logcmd () {
        echo $(stamp_time) INFO "${@}"
        sudo dd status=none oflag=append conv=notrunc of=$LOG_SCRIPT <<< "$(stamp_time) INFO ${@}"
    }
fi

logcmd "========================Start of dup script========================"

# upgrade procedure
logcmd "Running zypper refresh..."
sudo zypper $ZYPPER_PARAMS_QUIET --gpg-auto-import-keys refresh

logcmd "Running zypper dist-upgrade..."
sudo zypper $ZYPPER_PARAMS_QUIET dist-upgrade $ZYPPER_PARAMS_DUP

logcmd "Running flatpak update..."
flatpak update $FLATPAK_PARAMS_QUIET

# post-upgrade checks
logcmd "Performing post-upgrade system configuration checks..."
for ((i = 0; i < ${#SYSTEM_FILES[@]}; i++)); do
    SYSTEM_FILE=$(echo "${SYSTEM_FILES[$i]}" | cut -d " " -f2)
    if sudo cmp ${SYSTEM_FILES[$i]} &>/dev/null; then
        logcmd "No need to fix file: $SYSTEM_FILE."
    else
        SYSTEMD_NEEDS_RELOAD="yes"
        sudo cp ${SYSTEM_FILES[$i]}
        logcmd "Fixed file: $SYSTEM_FILE."
    fi
done

if [ "$SYSTEMD_NEEDS_RELOAD" = "yes" ]; then
    logcmd "Running systemctl daemon-reload..."
    sudo systemctl daemon-reload
fi

# check if virt manager default interface has been lost
if sudo test ! -f "/var/lib/libvirt/network/default.xml"; then
    if sudo virsh net-list --all | grep '^\s*default' | awk '{print $2}'| grep --quiet "active"; then
        logcmd "Virtual manager default network is already configured and active. Nothing to do."
    else
        logcmd "Reinstalling libvirt and virt-manager packages..."
        sudo zypper $ZYPPER_PARAMS_QUIET install --force libvirt virt-manager
        sudo sed -i 's/^FirewallBackend=.*/FirewallBackend=iptables/' /etc/firewalld/firewalld.conf
        sudo sed -i 's/^firewall_backend =.*/firewall_backend = "iptables"/' /etc/libvirt/network.conf
        sudo systemctl restart firewalld
        if ip link show virbr0 &> /dev/null; then
            logcmd "Recreating virbr0 bridge interface..."

            sudo virsh net-undefine default &> /dev/null
            sudo virsh net-destroy default &> /dev/null
            sudo systemctl enable --now libvirtd
            sudo systemctl enable virtlogd.socket
            sudo systemctl restart libvirtd.service

            logcmd "Applying virtual manager default network configuration..."
            sudo virsh net-define $LIBVIRT_DEFAULT_NETWORK_TPL
            sudo virsh net-autostart default
            sudo firewall-cmd --complete-reload
            sudo virsh net-start default
        fi
    fi
fi

# load settings from all system configuration files
logcmd "Loading settings from all system configuration files..."
sudo sysctl --system --quiet
